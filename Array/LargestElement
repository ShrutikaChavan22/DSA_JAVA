import java.util.*;
public class LargestElement{
   public static void main(String args[]){
    Scanner sc=new Scanner(System.in);
    int[] arr = {10, 78, 39, 29, 45};
    int largest=arr[0];
    for (int i = 0; i < arr.length; i++) {
        if(arr[i]>largest){
            largest=arr[i];
        }   
    }
    System.out.println("Largest Element: "+largest);
    }   
}
