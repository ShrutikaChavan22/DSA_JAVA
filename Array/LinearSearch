public class LinearSearch{
    public static void main(String args[]){
        int[] arr={15,60,43,19,13};
        int x=19;
        boolean flag =false;
        for(int i=0;i<arr.length;i++){
            if(arr[i]==x){
                flag=true;
                break;
            }
        }
        if(flag==true){
            System.out.println("Element is found");
        }
        else{
            System.out.println("Element is not found");
        }
    }
}
